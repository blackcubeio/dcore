{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "title": {
            "type": "string",
            "title": "Titre",
            "description": "Titre du CTA"
        },
        "description": {
            "type": "string",
            "format": "wysiwyg",
            "options": {
                "theme": "snow",
                "modules": {
                    "toolbar": [["bold", "italic", "underline", "strike"], [{"list": "bullet"}], ["link"]]
                },
                "formats": ["bold", "italic", "link", "underline", "strike", "list"]
            },
            "title": "Description",
            "description": "Texte d'accompagnement"
        },
        "label": {
            "type": "string",
            "title": "Bouton",
            "description": "Libellé du bouton"
        },
        "route": {
            "type": "string",
            "title": "Cible",
            "description": "Élément cible (route interne)"
        },
        "url": {
            "type": "string",
            "title": "Cible (URL)",
            "description": "Lien brut (utilisé si pas de route)"
        }
    },
    "required": ["title", "label"]
}