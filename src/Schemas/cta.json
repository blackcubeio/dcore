{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "level": {
            "type": "string",
            "format": "dropdownlist",
            "multiple": false,
            "items": [
                {"value": 2, "title": "H2"},
                {"value": 3, "title": "H3"},
                {"value": 4, "title": "H4"},
                {"value": 5, "title": "H5"},
                {"value": 6, "title": "H6"}
            ],
            "title": "Level",
            "description": "CTA heading level (h2-h6)"
        },
        "title": {
            "type": "string",
            "title": "Title",
            "description": "CTA title"
        },
        "description": {
            "type": "string",
            "format": "wysiwyg",
            "options": {
                "theme": "snow",
                "modules": {
                    "toolbar": [["bold", "italic", "underline", "strike"], [{"list": "bullet"}], ["link"]]
                },
                "formats": ["bold", "italic", "link", "underline", "strike", "list"]
            },
            "title": "Description",
            "description": "Accompanying text"
        },
        "label": {
            "type": "string",
            "title": "Button",
            "description": "Button label"
        },
        "route": {
            "type": "string",
            "field": "routes",
            "title": "Target",
            "description": "Target element (internal route)"
        },
        "url": {
            "type": "string",
            "title": "Target (URL)",
            "description": "Raw link (used if no route)"
        }
    },
    "required": ["level", "title"]
}
