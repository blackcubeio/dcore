{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "inLanguage": {
            "type": "string",
            "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
            "maxLength": 5,
            "title": "Langue principale",
            "description": "Code BCP 47 : fr, fr-FR, en-US, de-DE…"
        },
        "hasSearchAction": {
            "type": "boolean",
            "format": "checkbox",
            "title": "Activer le Sitelinks Searchbox",
            "description": "Google affiche un champ de recherche directement dans les résultats.",
            "default": false
        },
        "searchTarget": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://.+\\{search_term_string\\}.*$",
            "maxLength": 500,
            "title": "URL de recherche",
            "description": "URL template avec {search_term_string}. Ex : https://www.example.com/search?q={search_term_string}"
        }
    },
    "required": []
}
