{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "group": {
            "type": "string",
            "format": "checkbox",
            "title": "Group",
            "description": "Group with adjacent FAQ"
        },
        "title": {
            "type": "string",
            "title": "Question",
            "description": "FAQ question"
        },
        "description": {
            "type": "string",
            "format": "wysiwyg",
            "options": {
                "theme": "snow",
                "modules": {
                    "toolbar": [["bold", "italic", "underline", "strike"], [{"list": "bullet"}], ["link"]]
                },
                "formats": ["bold", "italic", "link", "underline", "strike", "list"]
            },
            "title": "Answer",
            "description": "Answer to the question"
        }
    },
    "required": ["title", "description"]
}
