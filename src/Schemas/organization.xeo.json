{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "organizationType": {
            "type": "string",
            "multiple": false,
            "format": "dropdownlist",
            "items": [
                {"title": "Organization", "value": "Organization"},
                {"title": "Corporation", "value": "Corporation"},
                {"title": "LocalBusiness", "value": "LocalBusiness"},
                {"title": "OnlineStore", "value": "OnlineStore"},
                {"title": "OnlineBusiness", "value": "OnlineBusiness"},
                {"title": "EducationalOrganization", "value": "EducationalOrganization"},
                {"title": "GovernmentOrganization", "value": "GovernmentOrganization"},
                {"title": "MedicalOrganization", "value": "MedicalOrganization"},
                {"title": "NGO", "value": "NGO"},
                {"title": "SportsOrganization", "value": "SportsOrganization"},
                {"title": "PerformingGroup", "value": "PerformingGroup"},
                {"title": "Airline", "value": "Airline"},
                {"title": "NewsMediaOrganization", "value": "NewsMediaOrganization"},
                {"title": "ResearchOrganization", "value": "ResearchOrganization"}
            ],
            "title": "Organization type",
            "description": "Schema.org subtype. Google recommends OnlineStore for e-commerce, LocalBusiness for brick-and-mortar.",
            "default": "Organization"
        },
        "logo": {
            "type": "string",
            "format": "file",
            "fileType": "png, jpg, jpeg, svg",
            "title": "Logo",
            "description": "Square format recommended, minimum 112×112px. PNG, JPEG, SVG."
        },
        "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "title": "Contact email",
            "description": "Organization's primary email."
        },
        "telephone": {
            "type": "string",
            "pattern": "^\\+?[0-9\\s\\-\\.\\(\\)]{6,20}$",
            "maxLength": 30,
            "title": "Phone",
            "description": "International format recommended: +33-1-42-68-53-00."
        },
        "streetAddress": {
            "type": "string",
            "maxLength": 255,
            "title": "Address",
            "description": "Street number and name."
        },
        "postalCode": {
            "type": "string",
            "pattern": "^[A-Z0-9\\s\\-]{2,10}$",
            "maxLength": 10,
            "title": "Postal code",
            "description": "E.g.: 75008, 10115, SW1A 1AA."
        },
        "addressLocality": {
            "type": "string",
            "maxLength": 255,
            "title": "City"
        },
        "addressRegion": {
            "type": "string",
            "maxLength": 255,
            "title": "Region",
            "description": "Department, state, or region."
        },
        "addressCountry": {
            "type": "string",
            "pattern": "^[A-Z]{2}$",
            "maxLength": 2,
            "title": "Country",
            "description": "ISO 3166-1 alpha-2 code (FR, US, DE, GB…)."
        },
        "vatID": {
            "type": "string",
            "pattern": "^[A-Z]{2}[A-Z0-9]{2,13}$",
            "maxLength": 15,
            "title": "VAT number",
            "description": "Intra-community VAT (e.g.: FR12345678901)."
        },
        "iso6523Code": {
            "type": "string",
            "pattern": "^[0-9]{4}:[A-Z0-9]+$",
            "maxLength": 30,
            "title": "ISO 6523 code / SIRET",
            "description": "ISO 6523 legal identifier (e.g.: 0009:44306184100039 for a SIRET)."
        },
        "sameAs": {
            "type": "string",
            "format": "textarea",
            "title": "Social networks and profiles",
            "description": "One URL per line. LinkedIn, Twitter/X, Facebook, Instagram, YouTube, Wikidata…"
        },
        "contactType": {
            "type": "string",
            "multiple": false,
            "format": "dropdownlist",
            "items": [
                {"title": "Customer service", "value": "customer service"},
                {"title": "Sales", "value": "sales"},
                {"title": "Technical support", "value": "technical support"},
                {"title": "Billing", "value": "billing"},
                {"title": "Reservations", "value": "reservations"},
                {"title": "Credit card support", "value": "credit card support"},
                {"title": "Emergency", "value": "emergency"},
                {"title": "Baggage tracking", "value": "baggage tracking"},
                {"title": "Roadside assistance", "value": "roadside assistance"},
                {"title": "Package tracking", "value": "package tracking"}
            ],
            "title": "Contact type",
            "description": "Primary contact point type."
        },
        "foundingDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2}(-\\d{2})?)?$",
            "maxLength": 10,
            "title": "Founding date",
            "description": "Format: YYYY, YYYY-MM, or YYYY-MM-DD."
        },
        "numberOfEmployees": {
            "type": "string",
            "pattern": "^[0-9]+(-[0-9]+)?$",
            "maxLength": 15,
            "title": "Number of employees",
            "description": "Exact number or range (e.g.: 3500, 10-50)."
        }
    },
    "required": []
}
