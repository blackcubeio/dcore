{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "organizationType": {
            "type": "string",
            "multiple": false,
            "format": "dropdownlist",
            "items": [
                {"title": "Organization", "value": "Organization"},
                {"title": "Corporation", "value": "Corporation"},
                {"title": "LocalBusiness", "value": "LocalBusiness"},
                {"title": "OnlineStore", "value": "OnlineStore"},
                {"title": "OnlineBusiness", "value": "OnlineBusiness"},
                {"title": "EducationalOrganization", "value": "EducationalOrganization"},
                {"title": "GovernmentOrganization", "value": "GovernmentOrganization"},
                {"title": "MedicalOrganization", "value": "MedicalOrganization"},
                {"title": "NGO", "value": "NGO"},
                {"title": "SportsOrganization", "value": "SportsOrganization"},
                {"title": "PerformingGroup", "value": "PerformingGroup"},
                {"title": "Airline", "value": "Airline"},
                {"title": "NewsMediaOrganization", "value": "NewsMediaOrganization"},
                {"title": "ResearchOrganization", "value": "ResearchOrganization"}
            ],
            "title": "Type d'organisation",
            "description": "Sous-type Schema.org. Google recommande OnlineStore pour e-commerce, LocalBusiness pour commerce physique.",
            "default": "Organization"
        },
        "logo": {
            "type": "string",
            "format": "file",
            "fileType": "png, jpg, jpeg, svg",
            "title": "Logo",
            "description": "Format carré recommandé, minimum 112×112px. PNG, JPEG, SVG."
        },
        "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "title": "Email de contact",
            "description": "Email principal de l'organisation."
        },
        "telephone": {
            "type": "string",
            "pattern": "^\\+?[0-9\\s\\-\\.\\(\\)]{6,20}$",
            "maxLength": 30,
            "title": "Téléphone",
            "description": "Format international recommandé : +33-1-42-68-53-00."
        },
        "streetAddress": {
            "type": "string",
            "maxLength": 255,
            "title": "Adresse",
            "description": "Numéro et nom de rue."
        },
        "postalCode": {
            "type": "string",
            "pattern": "^[A-Z0-9\\s\\-]{2,10}$",
            "maxLength": 10,
            "title": "Code postal",
            "description": "Ex : 75008, 10115, SW1A 1AA."
        },
        "addressLocality": {
            "type": "string",
            "maxLength": 255,
            "title": "Ville"
        },
        "addressRegion": {
            "type": "string",
            "maxLength": 255,
            "title": "Région",
            "description": "Département, état ou région."
        },
        "addressCountry": {
            "type": "string",
            "pattern": "^[A-Z]{2}$",
            "maxLength": 2,
            "title": "Pays",
            "description": "Code ISO 3166-1 alpha-2 (FR, US, DE, GB…)."
        },
        "vatID": {
            "type": "string",
            "pattern": "^[A-Z]{2}[A-Z0-9]{2,13}$",
            "maxLength": 15,
            "title": "Numéro de TVA",
            "description": "TVA intracommunautaire (ex : FR12345678901)."
        },
        "iso6523Code": {
            "type": "string",
            "pattern": "^[0-9]{4}:[A-Z0-9]+$",
            "maxLength": 30,
            "title": "Code ISO 6523 / SIRET",
            "description": "Identifiant légal ISO 6523 (ex : 0009:44306184100039 pour un SIRET)."
        },
        "sameAs": {
            "type": "string",
            "format": "textarea",
            "title": "Réseaux sociaux et profils",
            "description": "Une URL par ligne. LinkedIn, Twitter/X, Facebook, Instagram, YouTube, Wikidata…"
        },
        "contactType": {
            "type": "string",
            "multiple": false,
            "format": "dropdownlist",
            "items": [
                {"title": "Service client", "value": "customer service"},
                {"title": "Commercial", "value": "sales"},
                {"title": "Support technique", "value": "technical support"},
                {"title": "Facturation", "value": "billing"},
                {"title": "Réservations", "value": "reservations"},
                {"title": "Support carte bancaire", "value": "credit card support"},
                {"title": "Urgences", "value": "emergency"},
                {"title": "Suivi bagages", "value": "baggage tracking"},
                {"title": "Assistance routière", "value": "roadside assistance"},
                {"title": "Suivi colis", "value": "package tracking"}
            ],
            "title": "Type de contact",
            "description": "Nature du point de contact principal."
        },
        "foundingDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2}(-\\d{2})?)?$",
            "maxLength": 10,
            "title": "Date de fondation",
            "description": "Format YYYY, YYYY-MM ou YYYY-MM-DD."
        },
        "numberOfEmployees": {
            "type": "string",
            "pattern": "^[0-9]+(-[0-9]+)?$",
            "maxLength": 15,
            "title": "Nombre d'employés",
            "description": "Nombre exact ou tranche (ex : 3500, 10-50)."
        }
    },
    "required": []
}
