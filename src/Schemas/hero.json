{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "overline": {
            "type": "string",
            "title": "Overline",
            "description": "Section overline"
        },
        "title": {
            "type": "string",
            "title": "Title",
            "description": "Hero title (h1)"
        },
        "description": {
            "type": "string",
            "format": "wysiwyg",
            "options": {
                "theme": "snow",
                "modules": {
                    "toolbar": [["bold", "italic", "underline", "strike"], [{"list": "bullet"}], ["link"]]
                },
                "formats": ["bold", "italic", "link", "underline", "strike", "list"]
            },
            "title": "Teasing",
            "description": "Teasing content"
        },
        "image": {
            "type": "string",
            "format": "file",
            "fileType": "png,jpg,svg",
            "title": "Image",
            "description": "Hero image"
        },
        "alt": {
            "type": "string",
            "title": "Alternate",
            "description": "Image alt attribute"
        },
        "label": {
            "type": "string",
            "title": "Button",
            "description": "CTA button label"
        },
        "route": {
            "type": "string",
            "field": "routes",
            "title": "Target",
            "description": "CTA target element (internal route)"
        },
        "url": {
            "type": "string",
            "title": "Target (URL)",
            "description": "Raw link (used if no route)"
        },
        "secondaryLabel": {
            "type": "string",
            "title": "Button",
            "description": "Secondary CTA button label"
        },
        "secondaryRoute": {
            "type": "string",
            "field": "routes",
            "title": "Target",
            "description": "Secondary CTA target element (internal route)"
        },
        "secondaryUrl": {
            "type": "string",
            "title": "Target (URL)",
            "description": "Secondary Raw link (used if no route)"
        }
    },
    "required": ["title", "description", "image", "alt"]
}
