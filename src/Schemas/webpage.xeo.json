{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "title": "Name",
            "description": "Page name"
        },
        "description": {
            "type": "string",
            "format": "wysiwyg",
            "options": {
                "theme": "snow",
                "modules": {
                    "toolbar": [["bold", "italic", "underline", "strike"], [{"list": "bullet"}], ["link"]]
                },
                "formats": ["bold", "italic", "link", "underline", "strike", "list"]
            },
            "title": "Description",
            "description": "Page description"
        },
        "image": {
            "type": "string",
            "format": "file",
            "fileType": "png,jpg,svg",
            "title": "Image",
            "description": "Main image"
        }
    },
    "required": ["name"]
}
