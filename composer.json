{
    "name": "blackcube/dcore",
    "description": "CMS core data layer",
    "keywords": [
        "cms",
        "content-management",
        "yii3",
        "active-record",
        "headless",
        "tree",
        "json-schema",
        "seo",
        "multilingual"
    ],
    "type": "library",
    "license": "BSD-3-Clause",
    "readme": "README.md",
    "homepage": "https://github.com/blackcubeio/dcore",
    "support": {
        "issues": "https://github.com/blackcubeio/dcore/issues",
        "source": "https://github.com/blackcubeio/dcore"
    },
    "authors": [
        {
            "name": "Philippe Gaultier",
            "email": "philippe@blackcube.io"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "blackcube/hazeltree": "^1.0",
        "blackcube/elastic": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/link": "^2.0",
        "yiisoft/active-record": "^1.0",
        "yiisoft/data": "^2.0",
        "yiisoft/db": "^2.0"
    },
    "require-dev": {
        "codeception/codeception": "^5.3",
        "codeception/module-asserts": "^3.3",
        "codeception/module-db": "^3.2",
        "httpsoft/http-message": "^1.1",
        "symfony/process": "^8.0",
        "vlucas/phpdotenv": "^5.6",
        "yiisoft/db-migration": "^2.0",
        "yiisoft/db-mysql": "^2.0",
        "yiisoft/di": "^1.4",
        "yiisoft/event-dispatcher": "^1.1",
        "yiisoft/factory": "^1.3",
        "yiisoft/injector": "^1.2",
        "yiisoft/test-support": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "Blackcube\\Dcore\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Blackcube\\Dcore\\Tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-devel": "1.x-dev"
        },
        "config-plugin-file": "config/configuration.php"
    },
    "config": {
        "sort-packages": true
    }
}
